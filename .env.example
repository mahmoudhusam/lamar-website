# Copy this file to ".env.local" for local development, and set the same
# variables in your hosting provider (e.g. Vercel) for production.
# Never commit your real .env.local — it is git-ignored.

# ── Database (PostgreSQL) ─────────────────────────────────────────────
# Any Postgres host works (Neon, Supabase, Railway…). Neon is recommended
# because it provides both a pooled and a direct (unpooled) URL.
# Pooled connection — used by the app at runtime.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# Direct/unpooled connection — used by the seed script.
DATABASE_URL_UNPOOLED="postgresql://user:password@host/dbname?sslmode=require"

# ── Authentication (NextAuth) ─────────────────────────────────────────
# Secret used to sign admin session tokens.
# Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET=""

# ── First admin account (created by `npx prisma db seed`) ─────────────
ADMIN_EMAIL="owner@example.com"
ADMIN_PASSWORD="choose-a-strong-password"
ADMIN_NAME="Site Owner"

# ── Cloudinary (project image uploads in the admin) ───────────────────
# Found on your Cloudinary dashboard. Format:
#   cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=""

# ── Email (Resend) — contact-form notifications ───────────────────────
# Without these, enquiries are still saved to the admin "Leads" inbox,
# but no notification email is sent.
RESEND_API_KEY=""
# A sender on a domain you've verified in Resend, e.g.
#   "LAMAR <offerte@your-domain.nl>"
CONTACT_FROM=""
# Fallback recipient if no contact email is set in the admin → Contact page.
CONTACT_EMAIL="info@your-domain.nl"

# ── SEO ───────────────────────────────────────────────────────────────
# Your production URL — used for the sitemap, canonical tags and the
# social share (OpenGraph) image URLs.
NEXT_PUBLIC_SITE_URL="https://your-domain.nl"
