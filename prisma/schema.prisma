generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  PROJECTS_EDITOR
  CONTENT_EDITOR
  GALLERY_EDITOR
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CONTENT_EDITOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryItem {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Content {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Settings {
  id       String @id @default(cuid())
  language String @default("nl")
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Project {
  id             String         @id @default(cuid())
  title          String
  slug           String         @unique
  description    String?
  coverImageUrl  String?
  order          Int            @default(0)
  bentoSlot      Int            @default(-1)
  published      Boolean        @default(true)
  images         ProjectImage[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model ProjectImage {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  order     Int      @default(0)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
