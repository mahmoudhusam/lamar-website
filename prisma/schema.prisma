generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  PROJECTS_EDITOR
  CONTENT_EDITOR
}

enum LeadSource {
  CONTACT
  QUOTE
}

enum LeadStatus {
  NEW
  CONTACTED
  WON
  ARCHIVED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CONTENT_EDITOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Content {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

/// An enquiry captured from the public contact form or quote wizard.
model Lead {
  id        String     @id @default(cuid())
  name      String
  email     String?
  phone     String?
  service   String?
  message   String
  source    LeadSource @default(CONTACT)
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())

  @@index([status])
  @@index([createdAt])
}

model Project {
  id             String         @id @default(cuid())
  title          String
  slug           String         @unique
  description    String?
  coverImageUrl  String?
  order          Int            @default(0)
  bentoSlot      Int            @default(-1)
  published      Boolean        @default(true)
  images         ProjectImage[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model ProjectImage {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  order     Int      @default(0)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
